<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/controllerSection"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:cardCornerRadius="@dimen/ih_card_corner"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/ih_card_inner_pad">

        <TextView
            style="@style/Widget.IH.Overline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/m3_panel_controller" />

        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/controller_pairing_title" />

        <TextView
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/controller_section_hint"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/pairing_secret_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/secretInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveManualSecret"
            style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/manual_pair_save" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartPairing"
            style="@style/Widget.InstantHotspot.Button.Expressive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/start_nearby_pairing" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanNearbyHosts"
            style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/scan_nearby_hosts" />

        <TextView
            android:id="@+id/controllerSelectedHostText"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClientHotspotOn"
            style="@style/Widget.InstantHotspot.Button.Expressive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/client_hotspot_on" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClientHotspotOff"
            style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/client_hotspot_off" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClientSyncConfig"
            style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/client_sync_hotspot_config" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/manual_hotspot_ssid">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/manualSsidInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/manual_hotspot_password">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/manualPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenWifiWithManual"
            style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/open_wifi_with_manual" />

        <TextView
            android:id="@+id/clientConnectionStatusText"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status_pill"
            android:text="@string/client_status_not_paired" />

        <TextView
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status_pill"
            android:text="@string/client_root_not_required" />

        <TextView
            android:id="@+id/controllerPairCodeText"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_status_pill"
            android:text="@string/pair_code_none" />

        <TextView
            android:id="@+id/controllerPairedDeviceText"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_status_pill"
            android:text="@string/controller_paired_device_none" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmPairing"
            style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:enabled="false"
            android:text="@string/confirm_pairing" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUnpairController"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/unpair_or_reset_controller" />

        <TextView
            android:id="@+id/clientHotspotConfigText"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/client_hotspot_config_empty"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            style="@style/TextAppearance.Material3.TitleSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/verbose_debug_title" />

        <TextView
            android:id="@+id/controllerDebugLogText"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_status_pill"
            android:padding="10dp"
            android:text="No debug events yet."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textIsSelectable="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnControllerClearLogs"
            style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/clear_logs" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
