<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/projectSection"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        style="@style/TextAppearance.Material3.TitleMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/project_tools_title" />

    <TextView
        style="@style/TextAppearance.Material3.BodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/project_tools_subtitle"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ih_section_gap"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:cardCornerRadius="@dimen/ih_card_corner"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/ih_card_inner_pad">

            <TextView
                style="@style/Widget.IH.Overline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/m3_tools_section_remote" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenRemoteTools"
                style="@style/Widget.InstantHotspot.Button.Expressive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_open_remote_tools" />

            <TextView
                style="@style/TextAppearance.Material3.BodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/btn_open_remote_tools_sub"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ih_section_gap"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        app:cardCornerRadius="@dimen/ih_card_corner"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/ih_card_inner_pad">

            <TextView
                style="@style/Widget.IH.Overline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/m3_tools_section_app" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenSettings"
                style="@style/Widget.InstantHotspot.Button.Expressive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/main_menu_settings" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckForUpdates"
                style="@style/Widget.InstantHotspot.Button.Expressive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_check_updates" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ih_section_gap"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        app:cardCornerRadius="@dimen/ih_card_corner"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/ih_card_inner_pad">

            <TextView
                style="@style/Widget.IH.Overline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/m3_tools_section_project" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenGithub"
                style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_open_github" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenReleases"
                style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_open_releases_module" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ih_section_gap"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        app:cardCornerRadius="@dimen/ih_card_corner"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/ih_card_inner_pad">

            <TextView
                style="@style/Widget.IH.Overline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/m3_tools_section_system" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTetheringSettings"
                style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_tethering_settings" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenBluetooth"
                style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_bluetooth_settings" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBatteryOpt"
                style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_battery_optimization" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAppInfo"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/btn_app_info" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ih_section_gap"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        app:cardCornerRadius="@dimen/ih_card_corner"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/ih_card_inner_pad">

            <TextView
                style="@style/Widget.IH.Overline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/m3_tools_section_diagnostics" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopyDebugLog"
                style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_copy_debug_log" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
