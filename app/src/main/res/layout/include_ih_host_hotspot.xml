<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:cardCornerRadius="@dimen/ih_card_corner"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/ih_card_inner_pad">

        <TextView
            style="@style/Widget.IH.Overline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/m3_host_ops_overline" />

        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/m3_host_hotspot_headline" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTogglePairingMode"
            style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/disable_pairing_mode" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHostReAdvertise"
            style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/host_re_advertise_now" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHostApproveCode"
            style="@style/Widget.InstantHotspot.Button.Expressive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:text="@string/approve_pending_code" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
