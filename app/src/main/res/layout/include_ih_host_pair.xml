<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:cardCornerRadius="@dimen/ih_card_corner"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/ih_card_inner_pad">

        <TextView
            style="@style/TextAppearance.Material3.HeadlineSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pair_headline_host" />

        <TextView
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/pair_subtitle_host"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            style="@style/TextAppearance.Material3.TitleSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/host_pairing_mode_overline" />

        <TextView
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/host_pairing_mode_hint_pair_tab"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHostPairingModeToggle"
            style="@style/Widget.InstantHotspot.Button.Expressive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/enable_pairing_mode" />

        <!-- Always visible (not verbose-only) so a short code + approve do not depend on "verbose". -->
        <TextView
            style="@style/TextAppearance.Material3.TitleSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/pair_host_pending_title" />

        <TextView
            android:id="@+id/hostPendingCodeText"
            style="@style/Widget.IH.PairCodeDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_status_pill"
            android:gravity="center"
            android:minHeight="@dimen/ih_pair_code_min_height"
            android:padding="12dp"
            android:text="@string/pending_code_none" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHostApproveOnPair"
            style="@style/Widget.InstantHotspot.Button.Expressive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:text="@string/approve_pending_code" />

        <TextView
            style="@style/TextAppearance.Material3.TitleSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/pair_section_paired_controllers" />

        <LinearLayout
            android:id="@+id/hostPairedControllersList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/hostPairCompactHint"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/pair_verbose_off_hint"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/hostPairVerboseGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/Widget.IH.Overline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/m3_subheader_status" />

            <TextView
                android:id="@+id/hostPairingStatusText"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_status_pill"
                android:padding="10dp"
                android:text="@string/host_pairing_status_unknown" />

            <TextView
                android:id="@+id/hostRootStatusText"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_status_pill"
                android:padding="10dp"
                android:text="@string/root_status_unknown" />

            <TextView
                android:id="@+id/hostPairedDeviceText"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_status_pill"
                android:padding="10dp"
                android:text="@string/host_paired_device_none" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchHostBondAllowlist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/host_bond_allowlist" />

            <TextView
                style="@style/TextAppearance.Material3.BodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/host_bond_allowlist_summary"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnpairHost"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/unpair_or_reset_host" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
