<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:cardCornerRadius="@dimen/ih_card_corner"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/ih_card_inner_pad">

        <TextView
            style="@style/TextAppearance.Material3.HeadlineSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pair_headline_controller" />

        <TextView
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/pair_subtitle_controller"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <!-- Primary path: one tall action block (LocalSend-style) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHighest"
            app:cardCornerRadius="@dimen/ih_pair_block_radius"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartPairing"
                    style="@style/Widget.InstantHotspot.Button.Expressive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/start_nearby_pairing" />

                <TextView
                    android:id="@+id/controllerPairCodeText"
                    style="@style/Widget.IH.PairCodeDisplay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:minHeight="@dimen/ih_pair_code_min_height"
                    android:padding="12dp"
                    android:background="@drawable/bg_status_pill"
                    android:text="@string/pair_code_none" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmPairing"
                    style="@style/Widget.InstantHotspot.Button.Expressive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:enabled="false"
                    android:text="@string/confirm_pairing" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- "or" divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="?attr/colorOutlineVariant" />

            <TextView
                style="@style/TextAppearance.Material3.LabelMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/pair_divider_or"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="?attr/colorOutlineVariant" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/pairing_secret_hint"
            app:boxStrokeColor="?attr/colorPrimary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/secretInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions|textVisiblePassword"
                android:minLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveManualSecret"
            style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/manual_pair_save" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanNearbyHosts"
            style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/scan_nearby_hosts" />

        <TextView
            android:id="@+id/controllerSelectedHostText"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/controllerPairedDeviceText"
            style="@style/TextAppearance.Material3.BodyLarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_status_pill"
            android:padding="12dp"
            android:text="@string/controller_paired_device_none" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUnpairController"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/unpair_or_reset_controller" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
