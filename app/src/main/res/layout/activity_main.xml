<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/titleText"
            style="@style/TextAppearance.Material3.HeadlineSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_title" />

        <TextView
            android:id="@+id/appVersionText"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/author_byline"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_magisk_notice"
            android:lineSpacingExtra="2dp"
            android:text="@string/magisk_banner_host"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchVerboseMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/ui_mode_verbose" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <RadioGroup
                android:id="@+id/modeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <RadioButton
                    android:id="@+id/radioHost"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_host" />

                <RadioButton
                    android:id="@+id/radioController"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/mode_controller" />
            </RadioGroup>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/hostSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/host_pairing_title" />

                <TextView
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/host_section_hint"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/hostVerboseTitleText"
                    style="@style/TextAppearance.Material3.TitleSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/host_install_compat_title" />

                <TextView
                    android:id="@+id/hostInstallCompatText"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/hostSecretText"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/pairing_not_set"
                    android:textIsSelectable="true" />

                <TextView
                    android:id="@+id/hostPendingCodeText"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_status_pill"
                    android:text="@string/pending_code_none" />

                <TextView
                    android:id="@+id/hostPairingStatusText"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_status_pill"
                    android:text="@string/host_pairing_status_unknown" />

                <TextView
                    android:id="@+id/hostRootStatusText"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_status_pill"
                    android:text="@string/root_status_unknown" />

                <TextView
                    android:id="@+id/hostPairedDeviceText"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_status_pill"
                    android:text="@string/host_paired_device_none" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTogglePairingMode"
                    style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/disable_pairing_mode" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHostReAdvertise"
                    style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/host_re_advertise_now" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHostApproveCode"
                    style="@style/Widget.InstantHotspot.Button.Expressive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:enabled="false"
                    android:text="@string/approve_pending_code" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnpairHost"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/unpair_or_reset_host" />

                <TextView
                    android:id="@+id/controllerVerboseTitleText"
                    style="@style/TextAppearance.Material3.TitleSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/verbose_debug_title" />

                <TextView
                    android:id="@+id/hostDebugLogText"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_status_pill"
                    android:padding="10dp"
                    android:text="No debug events yet."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textIsSelectable="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHostClearLogs"
                    style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/clear_logs" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/controllerSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/controller_pairing_title" />

                <TextView
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/controller_section_hint"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/pairing_secret_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/secretInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textNoSuggestions"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveManualSecret"
                    style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/manual_pair_save" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartPairing"
                    style="@style/Widget.InstantHotspot.Button.Expressive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/start_nearby_pairing" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClientHotspotOn"
                    style="@style/Widget.InstantHotspot.Button.Expressive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/client_hotspot_on" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClientHotspotOff"
                    style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/client_hotspot_off" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClientSyncConfig"
                    style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/client_sync_hotspot_config" />

                <TextView
                    android:id="@+id/clientConnectionStatusText"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_status_pill"
                    android:text="@string/client_status_not_paired" />

                <TextView
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_status_pill"
                    android:text="@string/client_root_not_required" />

                <TextView
                    android:id="@+id/controllerPairCodeText"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_status_pill"
                    android:text="@string/pair_code_none" />

                <TextView
                    android:id="@+id/controllerPairedDeviceText"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_status_pill"
                    android:text="@string/controller_paired_device_none" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmPairing"
                    style="@style/Widget.InstantHotspot.Button.Expressive.Tonal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:enabled="false"
                    android:text="@string/confirm_pairing" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnpairController"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/unpair_or_reset_controller" />

                <TextView
                    android:id="@+id/clientHotspotConfigText"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/client_hotspot_config_empty"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    style="@style/TextAppearance.Material3.TitleSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/verbose_debug_title" />

                <TextView
                    android:id="@+id/controllerDebugLogText"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_status_pill"
                    android:padding="10dp"
                    android:text="No debug events yet."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textIsSelectable="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnControllerClearLogs"
                    style="@style/Widget.InstantHotspot.Button.Expressive.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/clear_logs" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
