<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="2dp"
        android:text="@string/widget_button"
        android:textColor="#B3FFFFFF"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widgetPairedName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingBottom="2dp"
        android:textColor="#8CFFFFFF"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/widgetApState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="4dp"
        android:textColor="#8CFFFFFF"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widgetHotspotOn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="#2D2D2D"
            android:gravity="center"
            android:minHeight="40dp"
            android:padding="8dp"
            android:text="@string/widget_hotspot_on"
            android:textColor="#CCFFAC"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetHotspotOff"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="#2D2D2D"
            android:gravity="center"
            android:minHeight="40dp"
            android:padding="8dp"
            android:text="@string/widget_hotspot_off"
            android:textColor="#FFABAB"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
